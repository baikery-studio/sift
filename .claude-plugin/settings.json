{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_SUBPROCESS_ENV_SCRUB": "1"
  },
  "permissions": {
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit --no-gpg-sign:*)",
      "Bash(git reset --hard:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/.npmrc)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*id_rsa*)",
      "Write(**/*id_ed25519*)",
      "Write(./secrets/**)",
      "Write(**/.aws/**)",
      "Write(**/.ssh/**)",
      "Write(**/.npmrc)",
      "Write(**/.git/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*id_rsa*)",
      "Edit(**/*id_ed25519*)",
      "Edit(./secrets/**)",
      "Edit(**/.aws/**)",
      "Edit(**/.ssh/**)",
      "Edit(**/.npmrc)",
      "Edit(**/.git/**)",
      "Write(./.harness/**)",
      "Write(./.canary/**)",
      "Edit(./.harness/**)",
      "Edit(./.canary/**)",
      "MultiEdit(./.harness/**)",
      "MultiEdit(./.canary/**)"
    ],
    "ask": [
      "Bash(rm -r:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fx:*)",
      "Bash(git push:*)"
    ]
  },
  "sandbox": {
    "failIfUnavailable": false,
    "network": {
      "deniedDomains": [
        "169.254.169.254",
        "metadata.google.internal",
        "metadata.azure.com",
        "pastebin.com",
        "hastebin.com",
        "transfer.sh",
        "0x0.st",
        "paste.ee",
        "termbin.com",
        "ix.io"
      ]
    },
    "filesystem": {
      "denyRead": [
        ".env",
        ".env.*",
        "!.env.example",
        "secrets/**",
        "**/*.pem",
        "**/*.key",
        "**/*id_rsa*",
        "**/*id_ed25519*",
        "**/.aws/**",
        "**/.ssh/**"
      ],
      "allowRead": [
        ".env.example",
        ".env.sample",
        "docs/**"
      ]
    }
  }
}
